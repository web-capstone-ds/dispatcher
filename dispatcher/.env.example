# DB — read-only 계정만 허용
DB_HOST=host.docker.internal
DB_PORT=5434
DB_NAME=ds_historian
DB_USER=historian
DB_PASSWORD=CHANGE_ME
DB_STATEMENT_TIMEOUT_MS=30000
DB_POOL_MAX=5

# AI 서버 — 단방향 Push 전용
AI_SERVER_URL=http://host.docker.internal:8000/api/ingest
AI_SERVER_API_KEY=CHANGE_ME_DISPATCHER_KEY
AI_REQUEST_TIMEOUT_MS=10000

# 비식별화
HMAC_SECRET=CHANGE_ME_32_CHARS_MIN

# Dead letter
DEAD_LETTER_PATH=./dead_letter.jsonl

# 발송 완료 LOT 추적 파일
SENT_LOTS_PATH=./sent_lots.jsonl

# 배치 설정
BATCH_PAGE_SIZE=500
BACKOFF_STEPS_SEC=1,2,5,15,30,60
BACKOFF_MAX_ATTEMPTS=6

# Auth Sync
BACKEND_SNAPSHOT_URL=https://web-backend:8080/api/auth/snapshot
AUTH_SYNC_CRON=*/5 * * * *
AUTH_SYNC_DB_HOST=oracle-db
AUTH_SYNC_DB_PORT=5432
AUTH_SYNC_DB_NAME=oracle
AUTH_SYNC_DB_USER=oracle
AUTH_SYNC_DB_PASSWORD=CHANGE_ME
DISPATCHER_CERT=./certs/dispatcher.crt
DISPATCHER_KEY=./certs/dispatcher.key
BACKEND_CA_CERT=./certs/backend-ca.crt
